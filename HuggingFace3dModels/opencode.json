{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "cloudflare": {
      "enabled": false
    },
    "cloudflare-docs": {
      "enabled": false
    },
    "cloudflare-bindings": {
      "enabled": false
    },
    "cloudflare-builds": {
      "enabled": false
    },
    "cloudflare-observability": {
      "enabled": false
    },
    "cloudflare-browser": {
      "enabled": false
    },
    "colab-mcp": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/googlecolab/colab-mcp",
        "colab-mcp"
      ],
      "enabled": true,
      "timeout": 30000
    }
  }
}
